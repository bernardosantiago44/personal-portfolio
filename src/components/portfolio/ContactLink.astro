---
import type { ContactEntry } from '../../data/portfolio';

type Props = {
  item: ContactEntry;
};

const { item } = Astro.props;
---

<a
  href={item.href} target="_blank" rel="noopener noreferrer"
  class="group flex items-center justify-between gap-4 border-t border-(--color-border) py-5 transition duration-200 hover:border-(--color-border-strong)"
>
  <span>
    <span class="block font-mono text-xs uppercase tracking-[0.2em] text-(--color-muted)">
      {item.label}
    </span>
    <span class="mt-2 block wrap-break-word text-base text-(--color-text) sm:text-lg">
      {item.value}
    </span>
  </span>
  <span
    aria-hidden="true"
    class="shrink-0 text-lg text-(--color-muted) transition duration-200 group-hover:translate-x-1 group-hover:text-(--color-text)"
  >
    -&gt;
  </span>
</a>
