---
import BadgeList from './BadgeList.astro';
import type { ExperienceEntry } from '../../data/portfolio';

type Props = {
  entry: ExperienceEntry;
};

const { entry } = Astro.props;
---

<article class="grid gap-4 border-t border-(--color-border) py-6 sm:grid-cols-[minmax(8rem,12rem)_1fr] sm:gap-8 sm:py-8">
  <div class="space-y-1">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-(--color-muted)">
      {entry.period}
    </p>
    <p class="text-sm text-(--color-muted)">{entry.location}</p>
  </div>

  <div class="space-y-4">
    <div>
      <h3 class="text-xl font-medium text-(--color-text)">{entry.title}</h3>
      <p class="mt-1 text-base text-(--color-muted)">{entry.organization}</p>
    </div>
    <p class="max-w-3xl text-base leading-7 text-(--color-muted)">
      {entry.description}
    </p>
    <BadgeList items={entry.technologies} variant="compact" />
  </div>
</article>
