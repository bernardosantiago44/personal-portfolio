---
type ProjectListItem = {
	title: string;
	description: string;
};

type Props = {
	items: ProjectListItem[];
};

const { items } = Astro.props;
---

<div class="grid gap-3">
	{
		items.map((item) => (
			<article class="rounded-lg border border-(--color-border) bg-(--color-surface) p-5">
				<h3 class="text-base font-medium text-(--color-text)">{item.title}</h3>
				<p class="mt-2 text-base leading-7 text-(--color-muted)">{item.description}</p>
			</article>
		))
	}
</div>
