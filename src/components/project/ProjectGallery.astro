---
type GalleryItem = {
	title: string;
	description?: string;
	image?: string;
	alt?: string;
};

type Props = {
	items: GalleryItem[];
};

const { items } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2">
	{
		items.map((item) => (
			<figure class="overflow-hidden rounded-lg border border-white/10 bg-white/2.5">
				{
					item.image ? (
						<img src={item.image} alt={item.alt ?? item.title} class="aspect-4/3 w-full object-cover" loading="lazy" />
					) : (
						<div class="flex aspect-4/3 items-end border-b border-white/10 bg-[linear-gradient(135deg,rgba(255,255,255,0.08),rgba(255,255,255,0.015))] p-5">
							<span class="font-mono text-xs uppercase tracking-[0.22em] text-(--color-muted)">
								{item.title}
							</span>
						</div>
					)
				}
				<figcaption class="p-5">
					<h3 class="text-base font-medium text-(--color-text)">{item.title}</h3>
					{item.description && <p class="mt-2 text-sm leading-6 text-(--color-muted)">{item.description}</p>}
				</figcaption>
			</figure>
		))
	}
</div>
