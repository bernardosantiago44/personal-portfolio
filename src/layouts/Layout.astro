---
import '../styles/global.css';

type Props = {
	title?: string;
	description?: string;
};

const defaultTitle = 'Bernardo Santiago Marin | Portfolio';
const defaultDescription =
	'Portfolio of Bernardo Santiago Marin, a backend developer and computer science student building reliable backend systems, data tools, and full-stack products.';

const { title = defaultTitle, description = defaultDescription } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#050505" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="scroll-fade scroll-fade-top" aria-hidden="true"></div>
		<div class="scroll-fade scroll-fade-bottom" aria-hidden="true"></div>
		<slot />
	</body>
</html>
